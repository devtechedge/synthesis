# ── Required ───────────────────────────────────────────────
# Vercel Postgres (Neon) connection string. The only required variable.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# ── LLM (any one enables real reasoning; omit all for demo/simulated mode) ──
# OpenAI-compatible. Works with OpenAI, Groq, OpenRouter, or a local server.
OPENAI_API_KEY=
OPENAI_BASE_URL=                  # e.g. https://api.openai.com/v1  (Groq auto-detected if GROQ_API_KEY set)
OPENAI_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# Groq (free tier) alternative
GROQ_API_KEY=

# ── Tools (optional; simulated fallbacks exist for all) ────
TAVILY_API_KEY=
SERPER_API_KEY=
JINA_API_KEY=

# ── Optional integrations ──────────────────────────────────
# Langfuse tracing, Vercel KV checkpointer/cache, Vercel Blob artifacts
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
KV_REST_API_URL=
KV_REST_API_TOKEN=
BLOB_READ_WRITE_TOKEN=
